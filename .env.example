NUTRICIONISTA_ENDERECO=

# Preços dos planos
VALOR_PLANO_INICIAL=
VALOR_PLANO_ACOMPANHAMENTO=
VALOR_PLANO_PREMIUM=

# Webdiet
WEBDIET_URL=https://app.webdiet.com.br

    "db:seed": "tsx src/database/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^137.1.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "openai": "^4.28.0",
    "pg": "^8.11.3",
    "puppeteer": "^21.11.0",
    "twilio": "^4.23.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"

{
  "name": "nutri-system",
  "version": "1.0.0",
  "description": "Sistema de automação para consultório de nutrição clínica",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
